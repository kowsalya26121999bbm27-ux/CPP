#include <vector>
#include <algorithm>
#include <climits>

using namespace std;

class Solution {
public:
    long long maximumAmount(vector<vector<int>>& coins) {
        int m = coins.size();
        int n = coins[0].size();
        
        // dp[i][j][k] = max coins at (i, j) with k neutralizations used
        // Using long long to prevent overflow; initializing with a very small number
        vector<vector<vector<long long>>> dp(m, vector<vector<long long>>(n, vector<long long>(3, LLONG_MIN)));

        for (int i = 0; i < m; ++i) {
            for (int j = 0; j < n; ++j) {
                for (int k = 0; k < 3; ++k) {
                    long long current_val = coins[i][j];
                    
                    // Base case: Starting point
                    if (i == 0 && j == 0) {
                        dp[i][j][0] = current_val;
                        if (current_val < 0) {
                            dp[i][j][1] = 0; // Neutralize the first cell if negative
                        }
                        continue;
                    }

                    // Get max from top and left neighbors
                    long long from_prev = LLONG_MIN;
                    if (i > 0) from_prev = max(from_prev, dp[i-1][j][k]);
                    if (j > 0) from_prev = max(from_prev, dp[i][j-1][k]);

                    // Option 1: Don't neutralize this cell
                    if (from_prev != LLONG_MIN) {
                        dp[i][j][k] = max(dp[i][j][k], from_prev + current_val);
                    }

                    // Option 2: Use a neutralization here (if available and cell is negative)
                    if (k > 0 && current_val < 0) {
                        long long from_prev_k_minus_1 = LLONG_MIN;
                        if (i > 0) from_prev_k_minus_1 = max(from_prev_k_minus_1, dp[i-1][j][k-1]);
                        if (j > 0) from_prev_k_minus_1 = max(from_prev_k_minus_1, dp[i][j-1][k-1]);
                        
                        if (from_prev_k_minus_1 != LLONG_MIN) {
                            dp[i][j][k] = max(dp[i][j][k], from_prev_k_minus_1);
                        }
                    }
                }
            }
        }

        // Return the best result using 0, 1, or 2 neutralizations
        return max({dp[m-1][n-1][0], dp[m-1][n-1][1], dp[m-1][n-1][2]});
    }
};
