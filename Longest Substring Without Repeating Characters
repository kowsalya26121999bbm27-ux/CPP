#include <iostream>
#include <string>
#include <unordered_map>
#include <algorithm>
#include <vector>
class Solution
{
    public:
    int lengthOfLongestSubstring(std::string s)
    {
        std::unordered_map<char, int> seen_chars;
        int left = 0;
        int max_length = 0;
        for (int right = 0; right < (int)s.length(); ++right)
        {
            char current_char = s[right];
            if (seen_chars.find(current_char) != seen_chars.end() && seen_chars[current_char] >= left)
            {
                left = seen_chars[current_char] + 1;
            }
            seen_chars[current_char] = right;
            max_length = std::max(max_length, right - left + 1);
        }
        return max_length;
    }
};
